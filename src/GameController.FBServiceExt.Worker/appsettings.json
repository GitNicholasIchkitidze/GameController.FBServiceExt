{
    "Serilog": {
        "Using": [
            "Serilog.Sinks.Console",
            "Serilog.Sinks.Graylog",
            "Serilog.Enrichers.Environment",
            "Serilog.Enrichers.Process",
            "Serilog.Enrichers.Thread"
        ],
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Microsoft": "Warning",
                "Microsoft.Hosting.Lifetime": "Information",
                "System": "Warning"
            }
        },
        "Enrich": [
            "FromLogContext",
            "WithMachineName",
            "WithEnvironmentName",
            "WithProcessId",
            "WithProcessName",
            "WithThreadId"
        ],
        "WriteTo": [
            {
                "Name": "Console",
                "Args": {
                    "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext} {Message:lj} {Properties:j}{NewLine}{Exception}"
                }
            },
            {
                "Name": "Graylog",
                "Args": {
                    "hostnameOrAddress": "127.0.0.1",
                    "port": 12201,
                    "transportType": "Udp",
                    "facility": "GameController.FBServiceExt.Worker"
                }
            }
        ],
        "Properties": {
            "Application": "GameController.FBServiceExt",
            "ServiceRole": "Worker"
        }
    },
    "VotingWorkflow": {
        "OptionsSessionTtl": "00:10:00",
        "ConfirmationTimeout": "00:02:00",
        "Cooldown": "00:05:00",
        "ProcessedEventRetention": "1.00:00:00",
        "ProcessingLockTimeout": "00:00:30",
        "VoteStartTokens": [
            "GET_STARTED",
            "_voteStartFlag"
        ],
        "ConfirmationAcceptTokens": [
            "YES",
            "YESCONFIRMED",
            "CONFIRM:YES"
        ],
        "ConfirmationRejectTokens": [
            "NO",
            "NOCONFIRMED",
            "CONFIRM:NO"
        ],
        "OptionsExpirationBehavior": "Silent",
        "ConfirmationExpirationBehavior": "Silent",
        "CooldownResponseMode": "Message",
        "IncludeRemainingCooldownTime": true
    },
    "Candidates": {
        "Items": [
            {
                "Id": "candidate-1",
                "DisplayName": "Candidate 1",
                "Enabled": true
            },
            {
                "Id": "candidate-2",
                "DisplayName": "Candidate 2",
                "Enabled": true
            }
        ]
    },
    "RabbitMq": {
        "HostName": "localhost",
        "Port": 5672,
        "VirtualHost": "/",
        "UserName": "fbserviceext",
        "Password": "DevOnly_RabbitMq2026!",
        "RawIngressQueueName": "fbserviceext.raw.ingress",
        "NormalizedEventQueueName": "fbserviceext.normalized.events",
        "PrefetchCount": 64,
        "PublisherChannelPoolSize": 16
    },
    "WorkerExecution": {
        "RawIngressParallelism": 4,
        "NormalizedProcessingParallelism": 8
    },
    "Redis": {
        "ConnectionString": "localhost:6379",
        "KeyPrefix": "fbserviceext"
    },
    "SqlStorage": {
        "ConnectionString": "Server=localhost;Database=GameControllerFBServiceExt;Trusted_Connection=True;TrustServerCertificate=True;"
    }
}
