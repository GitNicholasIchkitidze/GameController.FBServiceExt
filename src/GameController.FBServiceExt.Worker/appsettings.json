{
    "Serilog":  {
                    "Using":  [
                                  "Serilog.Sinks.Console",
                                  "Serilog.Sinks.Graylog",
                                  "Serilog.Enrichers.Environment",
                                  "Serilog.Enrichers.Process",
                                  "Serilog.Enrichers.Thread"
                              ],
                    "MinimumLevel":  {
                                         "Default":  "Information",
                                         "Override":  {
                                                          "Microsoft":  "Warning",
                                                          "Microsoft.Hosting.Lifetime":  "Information",
                                                          "System":  "Warning"
                                                      }
                                     },
                    "Enrich":  [
                                   "FromLogContext",
                                   "WithMachineName",
                                   "WithEnvironmentName",
                                   "WithProcessId",
                                   "WithProcessName",
                                   "WithThreadId"
                               ],
                    "WriteTo":  [
                                    {
                                        "Name":  "Console",
                                        "Args":  {
                                                     "outputTemplate":  "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext} {Message:lj} {Properties:j}{NewLine}{Exception}"
                                                 }
                                    },
                                    {
                                        "Name":  "Graylog",
                                        "Args":  {
                                                     "hostnameOrAddress":  "127.0.0.1",
                                                     "port":  12201,
                                                     "transportType":  "Udp",
                                                     "facility":  "GameController.FBServiceExt.Worker"
                                                 }
                                    }
                                ],
                    "Properties":  {
                                       "Application":  "GameController.FBServiceExt",
                                       "ServiceRole":  "Worker"
                                   }
                },
    "WorkerExecution":  {
                            "RawIngressParallelism":  4,
                            "NormalizedProcessingParallelism":  8
                        },
    "MetaMessenger":  {
                          "Enabled":  true,
                          "PageAccessToken":  "",
                          "GraphApiVersion":  "v24.0",
                          "UserAccountNameCacheTtl":  "7.00:00:00"
                      }
}
