{
    "Logging":  {
                    "LogLevel":  {
                                     "Default":  "Warning",
                                     "Microsoft.Hosting.Lifetime":  "Information",
                                     "Microsoft.AspNetCore":  "Warning",
                                     "GameController.FBServiceExt":  "Information"
                                 }
                },
    "Serilog":  {
                    "MinimumLevel":  {
                                         "Default":  "Warning",
                                         "Override":  {
                                                          "Microsoft":  "Warning",
                                                          "Microsoft.AspNetCore":  "Warning",
                                                          "System":  "Warning",
                                                          "GameController.FBServiceExt":  "Information"
                                                      }
                                     }
                },
    "Graylog":  {
                    "MinimumLevel":  "Warning"
                },
    "MetaWebhook":  {
                        "RequireSignatureValidation":  false
                    },
    "RabbitMq":  {
                     "PublisherChannelPoolSize":  64,
                     "PublisherConfirmationsEnabled":  false,
                     "PublisherConfirmationTrackingEnabled":  false,
                     "ManagementApiBaseUrl":  "http://127.0.0.1:15672/api"
                 },
    "DevLogViewer":  {
                         "Enabled":  false
                     },
    "Redis":  {
                  "ConnectionString":  "localhost:6380"
              },
    "RuntimeMetrics":  {
                           "Enabled":  true,
                           "FlushIntervalMilliseconds":  2000,
                           "SnapshotTtlSeconds":  15
                       }
}

