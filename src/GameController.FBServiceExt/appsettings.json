{
    "Serilog": {
        "Using": [
            "Serilog.Sinks.Console",
            "Serilog.Sinks.Graylog",
            "Serilog.Enrichers.Environment",
            "Serilog.Enrichers.Process",
            "Serilog.Enrichers.Thread"
        ],
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Microsoft": "Warning",
                "Microsoft.AspNetCore": "Warning",
                "System": "Warning"
            }
        },
        "Enrich": [
            "FromLogContext",
            "WithMachineName",
            "WithEnvironmentName",
            "WithProcessId",
            "WithProcessName",
            "WithThreadId"
        ],
        "WriteTo": [
            {
                "Name": "Console",
                "Args": {
                    "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext} {Message:lj} {Properties:j}{NewLine}{Exception}"
                }
            },
            {
                "Name": "Graylog",
                "Args": {
                    "hostnameOrAddress": "127.0.0.1",
                    "port": 12201,
                    "transportType": "Udp",
                    "facility": "GameController.FBServiceExt.Api"
                }
            }
        ],
        "Properties": {
            "Application": "GameController.FBServiceExt",
            "ServiceRole": "Api"
        }
    },
    "AllowedHosts": "*",
    "MetaWebhook": {
        "VerifyToken": "FbVoTe",
        "AppSecret": "change-me-app-secret",
        "RequireSignatureValidation": true
    },
    "WebhookIngress": {
        "Source": "facebook-messenger",
        "MaxRequestBodySizeBytes": 262144
    },
    "RabbitMq": {
        "HostName": "localhost",
        "Port": 5672,
        "VirtualHost": "/",
        "UserName": "fbserviceext",
        "Password": "DevOnly_RabbitMq2026!",
        "RawIngressQueueName": "fbserviceext.raw.ingress",
        "NormalizedEventQueueName": "fbserviceext.normalized.events",
        "PrefetchCount": 64,
        "PublisherChannelPoolSize": 16
    }
}
